generator client {
  provider        = "prisma-client"
  output          = "../generated/prisma"
  previewFeatures = ["nativeDistinct", "relationJoins"]
  engineType      = "client"
}

datasource db {
  provider = "postgresql"
  schemas = ["krankenhaus"]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model Adresse {
  id             Int         @id @default(autoincrement())
  strasse        String
  hausnummer     String
  plz            String
  ort            String
  krankenhausId  Int         @unique @map("krankenhaus_id")
  krankenhaus    Krankenhaus @relation(fields: [krankenhausId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([krankenhausId])
  @@index([plz])
  @@map("adresse")
  @@schema("krankenhaus")
}

model Fachbereich {
  id             Int         @id @default(autoincrement())
  name           String
  beschreibung   String?
  leitung        String?
  anzahlaerzte   Int?
  krankenhausId  Int         @map("krankenhaus_id")
  krankenhaus    Krankenhaus @relation(fields: [krankenhausId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([krankenhausId], map: "fachbereichKrankenhausidIdx")
  @@index([name])
  @@map("fachbereich")
  @@schema("krankenhaus")
}

model Krankenhaus {
  id                Int           @id @default(autoincrement())
  version           Int           @default(0)
  name              String
  mitarbeiteranzahl Int?
  bettenanzahl      Int?
  email             String        @unique
  erzeugt           DateTime      @default(now()) @db.Timestamp(6)
  aktualisiert      DateTime      @default(now()) @db.Timestamp(6)  @updatedAt
  adresse           Adresse?
  fachbereiche      Fachbereich[]

  @@index([name])
  @@map("krankenhaus")
  @@schema("krankenhaus")
}
